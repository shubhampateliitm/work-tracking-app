FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install

COPY . .

ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

ARG NEXT_PUBLIC_CODE_EXECUTION_ENABLED=true
ENV NEXT_PUBLIC_CODE_EXECUTION_ENABLED=$NEXT_PUBLIC_CODE_EXECUTION_ENABLED

RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]
